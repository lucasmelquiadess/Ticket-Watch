PORT=4000
NODE_ENV=development
DATA_FILE=./data/store.json
VITE_API_BASE_URL=/api

# Monitor
MONITOR_ENABLED=true
MONITOR_ENGINE=html
DEFAULT_CHECK_INTERVAL_SECONDS=60
MIN_CHECK_INTERVAL_SECONDS=60
CHECK_TIMEOUT_MS=30000
ALLOW_NON_TICKETMASTER_URLS=false

# Docker only. Use true if MONITOR_ENGINE=playwright inside Docker.
INSTALL_PLAYWRIGHT=false

# Use a long random value and paste it in the Admin tab.
ADMIN_TOKEN=

# WhatsApp
# console: only logs messages in the backend terminal
# twilio: sends through Twilio WhatsApp
WHATSAPP_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional. For proactive production WhatsApp alerts, use an approved Twilio Content Template.
# Variables sent by the app:
# {{1}} name, {{2}} ticketTypeName, {{3}} sectorName, {{4}} eventName, {{5}} eventUrl
TWILIO_CONTENT_SID=
